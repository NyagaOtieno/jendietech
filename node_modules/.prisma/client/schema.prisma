// ----------------------
// Datasource & Generator
// ----------------------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------
// Enums
// ----------------------
enum Role {
  ADMIN
  TECHNICIAN
  STAFF
}

enum JobType {
  INSTALLATION
  RENEWAL
  FAULT_CHECK
  REPAIR
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  DONE
  NOT_DONE
  ESCALATED
}

// ----------------------
// Models
// ----------------------

model User {
  id         Int       @id @default(autoincrement())
  name       String
  email      String?   @unique
  phone      String?   @unique
  role       Role
  region     String?
  password   String
  online     Boolean   @default(false)
  lastLogin  DateTime?
  lastLogout DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sessions      Session[]
  jobs          Job[]          @relation("TechnicianJobs")
  rollCallUsers RollCallUser[]

  @@index([role])
  @@index([region])
}

model Job {
  id              Int       @id @default(autoincrement())
  vehicleReg      String
  jobType         JobType
  status          JobStatus @default(PENDING)
  scheduledDate   DateTime
  location        String?
  governorSerial  String?
  governorStatus  String?
  clientName      String?
  clientPhone     String?
  remarks         String?
  photoUrl        String?
  clientSignature String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // ✅ soft delete (important)

  assignedTechnician User? @relation("TechnicianJobs", fields: [technicianId], references: [id])
  technicianId       Int?

  photos          Photo[]
  history         JobHistory[]
  SmsOutbox       SmsOutbox[]
  FeedbackToken   FeedbackToken[]
  ServiceFeedback ServiceFeedback[]
  tracking        JobTracking[]

  // ✅ Better uniqueness rule (per day)
  @@index([vehicleReg, scheduledDate])
  @@index([status])
  @@index([technicianId])
}

model Session {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     Int
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  active     Boolean   @default(true)
  latitude   Float?
  longitude  Float?

  @@index([userId, active])
}

model RollCallUser {
  id         Int      @id @default(autoincrement())
  rollCall   RollCall @relation(fields: [rollCallId], references: [id])
  rollCallId Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  status    String?
  checkIn   DateTime?
  checkOut  DateTime?
  latitude  Float?
  longitude Float?

  @@index([userId])
}

model RollCall {
  id           Int            @id @default(autoincrement())
  date         DateTime       @default(now())
  region       String?
  presentUsers RollCallUser[]

  @@index([date])
}

model Photo {
  id         Int      @id @default(autoincrement())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId      Int
  url        String
  uploadedAt DateTime @default(now())

  @@index([jobId])
}

model JobHistory {
  id        Int       @id @default(autoincrement())
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     Int
  status    JobStatus
  remarks   String?
  latitude  Float?
  longitude Float?
  updatedBy Int
  createdAt DateTime  @default(now())

  @@index([jobId])
}

model SmsOutbox {
  id           BigInt    @id @default(autoincrement())
  jobId        Int?
  toPhone      String
  message      String
  status       String    @default("PENDING")
  scheduledFor DateTime  @default(now())
  sentAt       DateTime?
  retries      Int       @default(0)
  lastError    String?
  createdAt    DateTime  @default(now())

  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([status, scheduledFor])
}

model FeedbackToken {
  id        BigInt    @id @default(autoincrement())
  jobId     Int
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model ServiceFeedback {
  id        BigInt   @id @default(autoincrement())
  jobId     Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ----------------------
// 🔥 NEW: JOB TRACKING (Analytics Engine)
// ----------------------
model JobTracking {
  id            Int       @id @default(autoincrement())
  jobId         Int
  token         String    @unique
  visits        Int       @default(0)
  lastVisitedAt DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
